    }, [isVerified]);
    */

    // 마운트 시점에 다시 한번 확실히 체크 (간헐적 오류 방지 핵심)
    useEffect(() => {
        const checkAuth = () => {
            const authData = sessionStorage.getItem('kakao_auth_code');
            if (authData) {
                setIsVerified(true);
                // 인증 완료 후 스토리지 데이터가 더 이상 필요 없다면 여기서 지우거나 
