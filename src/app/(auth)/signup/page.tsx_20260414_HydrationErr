      const onlyNums = value.replace(/[^0-9]/g, '');

      if (onlyNums.length <= 3) {
        newValue = onlyNums;
      } else if (onlyNums.length <= 7) {
        newValue = `${onlyNums.slice(0, 3)}-${onlyNums.slice(3)}`;
      } else {
        newValue = `${onlyNums.slice(0, 3)}-${onlyNums.slice(3, 7)}-${onlyNums.slice(7, 11)}`;
      }
      */
